{
  "name": "filmklubb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && pnpm typecheck",
    "dev": "next dev",
    "dev:reset": "rm -rf .next && next dev -p 3000",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "preview": "next build && next start",
    "predeploy": "pnpm typecheck && pnpm build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.10.1",
    "geist": "^1.3.0",
    "ipaddr.js": "^2.4.0",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "zod": "^3.23.3"
  },
  "devDependencies": {
    "@types/eslint": "^8.56.10",
    "@types/node": "^24.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.18",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3"
  },
  "ct3aMetadata": {
    "initVersion": "7.38.1"
  },
  "packageManager": "pnpm@10.2.0"
}
